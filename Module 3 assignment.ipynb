    "import cv2\n",
    "import sys\n",
    "from matplotlib import pyplot as plt\n",
    "\n",
    "# Load the image\n",
    "image_path = \"98.jpg\"\n",
    "image = cv2.imread(image_path)\n",
    "# convert from BGR to RGB\n",
    "img_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n",
    "\n",
    "# Display inline\n",
    "plt.imshow(img_rgb)\n",
    "plt.show()"
   ]
